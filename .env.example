# ============================================================
# SmartCheckout — Variables d'environnement
# Copier ce fichier en .env et adapter les valeurs
# ============================================================

# --- APPLICATION ---
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change_this_to_a_random_64_character_string_in_production
APP_NAME=SmartCheckout
APP_URL=http://localhost:3000
API_URL=http://localhost:8000

# --- POSTGRESQL ---
POSTGRES_USER=smartcheckout
POSTGRES_PASSWORD=smartcheckout_dev
POSTGRES_DB=smartcheckout
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://smartcheckout:smartcheckout_dev@db:5432/smartcheckout

# --- REDIS ---
REDIS_PASSWORD=redis_dev_pass
REDIS_URL=redis://:redis_dev_pass@redis:6379/0

# --- JWT ---
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
ALGORITHM=HS256

# --- SMS (Twilio ou Africa's Talking) ---
SMS_PROVIDER=africas_talking
AFRICAS_TALKING_API_KEY=your_api_key
AFRICAS_TALKING_USERNAME=sandbox
SMS_SENDER_ID=SmartPay

# --- OBJECT STORAGE (MinIO en dev, S3 en prod) ---
STORAGE_BACKEND=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_RECEIPTS=receipts
MINIO_BUCKET_PRODUCTS=products
MINIO_USE_SSL=false

# AWS S3 (production)
# STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_S3_BUCKET=smartcheckout-prod
# AWS_S3_REGION=eu-west-1

# --- PAIEMENT V1 (Mobile Money manuel) ---
PAYMENT_MANUAL_TIMEOUT_MINUTES=30
PAYMENT_MANUAL_REMINDER_MINUTES=15

# --- PAIEMENT V2 (FedaPay) ---
FEDAPAY_API_KEY=
FEDAPAY_PUBLIC_KEY=
FEDAPAY_WEBHOOK_SECRET=
FEDAPAY_SANDBOX=true

# --- CELERY ---
CELERY_BROKER_URL=redis://:redis_dev_pass@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redis_dev_pass@redis:6379/2

# --- EMAIL (SMTP ou API Brevo) ---
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_smtp_login
SMTP_PASSWORD=your_brevo_smtp_key
SMTP_USE_TLS=true
SMTP_TIMEOUT_SECONDS=20
EMAIL_FROM=fiissa@your-domain.com
EMAIL_FROM_NAME=Fiissa
EMAIL_REPLY_TO=
EMAIL_REPLY_TO_NAME=
BREVO_API_KEY=

# --- MONITORING ---
SENTRY_DSN=

# --- SUPER ADMIN INITIAL ---
SUPERADMIN_EMAIL=admin@smartcheckout.africa
SUPERADMIN_PASSWORD=change_this_immediately
SUPERADMIN_PHONE=+221000000000

# --- FRONTEND ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SmartCheckout
